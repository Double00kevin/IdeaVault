[Unit]
Description=AIdeaPulse Ingestion Pipeline
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/doubl/AIdeaPulse
ExecStart=/home/doubl/AIdeaPulse/pipeline/.venv/bin/python -m pipeline.main
EnvironmentFile=/home/doubl/AIdeaPulse/pipeline/.env
StandardOutput=journal
StandardError=journal
TimeoutStartSec=18000

[Install]
WantedBy=multi-user.target
