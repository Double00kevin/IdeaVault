---
import BaseLayout from "../../layouts/BaseLayout.astro";
import IdeaCard from "../../components/IdeaCard";
import IdeaDetailGated from "../../components/IdeaDetailGated";

const { id } = Astro.params;
const API_BASE = import.meta.env.PUBLIC_API_URL ?? "http://localhost:8787/api";

let idea = null;
let error = null;

try {
  // Fetch without auth — server-side render gets anon/teaser view
  const res = await fetch(`${API_BASE}/ideas/${id}`);
  if (res.ok) {
    idea = await res.json();
  } else if (res.status === 404) {
    return Astro.redirect("/404");
  } else {
    error = `API error: ${res.status}`;
  }
} catch (e) {
  error = "Failed to fetch idea";
}
---

{idea ? (
  <BaseLayout
    title={`${idea.title} — AIdeaPulse`}
    description={idea.one_liner ?? "Discover AI-analyzed startup ideas on AIdeaPulse"}
    ogImage={`${API_BASE}/og/${idea.id ?? id}`}
  >
    <div class="mb-4">
      <a href="/" class="text-xs text-cyan-400 hover:underline">
        ← Browse all ideas
      </a>
    </div>

    {idea.gated ? (
      <IdeaDetailGated idea={idea} client:load />
    ) : (
      <IdeaCard idea={idea} client:load />
    )}

    <div class="mt-8 text-center">
      <a href="/" class="text-sm text-cyan-400 hover:underline">
        Browse more ideas →
      </a>
    </div>
  </BaseLayout>
) : (
  <BaseLayout title="Error — AIdeaPulse">
    <div class="border border-gray-800 rounded-lg bg-gray-900 p-8 text-center">
      <p class="text-white font-bold mb-1">Something went wrong.</p>
      <p class="text-gray-400 text-sm">{error}</p>
      <a href="/" class="text-cyan-400 hover:underline text-sm mt-3 inline-block">
        Browse all ideas →
      </a>
    </div>
  </BaseLayout>
)}
