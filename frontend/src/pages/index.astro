---
import BaseLayout from "../layouts/BaseLayout.astro";
import ConstellationBg from "../components/ConstellationBg";
import EcgDivider from "../components/EcgDivider";
---

<BaseLayout
  title="AIdeaPulse — AI-Powered Startup Ideas, Delivered Daily"
  description="We scan Reddit, Hacker News, Product Hunt, and 5 more sources every morning. Claude AI analyzes the signals. You get validated ideas before anyone else."
  fullWidth
>

  <!-- Full-page constellation background -->
  <div class="fixed inset-0 w-screen h-screen z-0 pointer-events-none">
    <ConstellationBg client:load />
  </div>

  <div class="relative z-10">

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden pt-24 pb-10">
    <!-- Radial glow -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[500px] rounded-full bg-cyan-500/10 blur-[120px]"></div>
    </div>

    <div class="relative max-w-landing mx-auto px-6 text-center">
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight leading-tight text-white">
        AI-Powered Startup Ideas.<br />
        <span class="text-cyan-400">Delivered Daily.</span>
      </h1>
      <!-- CTAs -->
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#"
          id="hero-cta-signup"
          class="bg-cyan-500 hover:bg-cyan-400 text-white font-semibold px-8 py-3 rounded-lg text-base transition-colors shadow-lg shadow-cyan-500/20"
        >
          Get Started Free &rarr;
        </a>
        <a
          href="#todays-idea"
          class="border border-gray-500 hover:border-cyan-500/50 text-white font-medium px-8 py-3 rounded-lg text-base transition-colors"
        >
          See Today's Idea
        </a>
      </div>

      <!-- Trust line -->
      <p class="mt-4 text-sm text-gray-500">
        No credit card required &middot; 1 free idea daily
      </p>
    </div>
  </section>

  <!-- ===== SOURCE STRIP ===== -->
  <section class="py-5">
    <div class="max-w-landing mx-auto px-6">
      <p class="text-center font-bold text-[0.95rem] tracking-[0.15em] text-[#9ca3af] uppercase">
        Scanning all sources every day
      </p>
    </div>
  </section>

  <!-- ECG Divider 1: between Source Strip and Today's Idea -->
  <div class="max-w-landing mx-auto px-6">
    <EcgDivider client:load index={0} />
  </div>

  <!-- ===== TODAY'S IDEA ===== -->
  <section id="todays-idea" class="py-10">
    <div class="max-w-landing mx-auto px-6">

      <!-- 3a. Free Idea Card -->
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 text-white">
        Today's Idea
      </h2>
      <p class="text-gray-400 text-center mb-12 max-w-xl mx-auto">
        Every day we surface one free AI-analyzed startup idea. Upgrade for full access to all ideas.
      </p>

      <div class="max-w-3xl mx-auto">
        <div class="relative">
          <div class="absolute -inset-2 bg-cyan-500/5 rounded-2xl blur-xl"></div>
          <div class="relative bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-6 sm:p-8">
            <!-- TODAY'S FREE IDEA badge -->
            <span class="absolute -top-3 left-6 bg-cyan-500 text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider">
              Today's Free Idea
            </span>

            <!-- Card header -->
            <div class="flex items-center gap-3 mb-4 mt-2">
              <span class="w-2.5 h-2.5 rounded-full bg-green-500 flex-shrink-0"></span>
              <span class="text-xs font-mono text-gray-500 uppercase tracking-wide">Low complexity</span>
              <span class="ml-auto bg-cyan-500/20 text-cyan-400 text-xs font-bold px-3 py-1 rounded-full font-mono">
                92 / 100
              </span>
            </div>

            <h3 class="text-xl sm:text-2xl font-bold mb-2 text-white">
              Niche Newsletter Monetization Analytics
            </h3>
            <p class="text-gray-300 leading-relaxed mb-6">
              Dashboard showing revenue-per-subscriber, churn prediction, and sponsorship pricing for newsletter creators. Integrates with Stripe, Substack, Beehiiv, and ConvertKit.
            </p>

            <!-- Details grid -->
            <div class="grid sm:grid-cols-2 gap-6 mb-6">
              <div>
                <span class="text-[11px] font-mono text-gray-500 uppercase tracking-wide">Problem</span>
                <p class="text-sm text-gray-300 mt-1">
                  Newsletter creators lack visibility into per-subscriber economics and can't optimize monetization without manual spreadsheet work.
                </p>
              </div>
              <div>
                <span class="text-[11px] font-mono text-gray-500 uppercase tracking-wide">Target Audience</span>
                <p class="text-sm text-gray-300 mt-1">
                  Independent newsletter creators with 1k-50k subscribers looking to go full-time or optimize revenue.
                </p>
              </div>
            </div>

            <!-- Market sizing -->
            <div class="grid grid-cols-3 gap-4 mb-6 p-4 bg-white/5 rounded-lg">
              <div>
                <span class="text-[11px] font-mono text-gray-500">TAM</span>
                <p class="font-mono text-sm font-bold text-white">$2.1B</p>
              </div>
              <div>
                <span class="text-[11px] font-mono text-gray-500">SAM</span>
                <p class="font-mono text-sm font-bold text-white">$340M</p>
              </div>
              <div>
                <span class="text-[11px] font-mono text-gray-500">SOM</span>
                <p class="font-mono text-sm font-bold text-white">$12M</p>
              </div>
            </div>

            <!-- Footer info -->
            <div class="flex flex-wrap items-center gap-4 text-xs text-gray-500">
              <span>2 competitors</span>
              <span>&middot;</span>
              <span>Freemium + $25/mo Pro</span>
              <span>&middot;</span>
              <span>MVP in 4-6 weeks</span>
              <span>&middot;</span>
              <span class="font-mono uppercase text-[10px]">producthunt</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 3b. Card Legend -->
      <div class="max-w-3xl mx-auto mt-10 rounded-xl border border-white/10 p-6 sm:p-8" style="background: rgba(255,255,255,0.02);">
        <h4 class="text-[11px] font-mono text-gray-500 uppercase tracking-wider mb-5">
          Reading an Idea Card
        </h4>
        <div class="grid sm:grid-cols-2 gap-x-8 gap-y-4 text-sm">
          <div>
            <span class="font-semibold text-white">Complexity Dot</span>
            <span class="text-gray-400"> — Green = low, Yellow = medium, Red = high build complexity</span>
          </div>
          <div>
            <span class="font-semibold text-white">Opportunity Score</span>
            <span class="text-gray-400"> — AI-generated score (0-100) based on demand, feasibility, and market gap</span>
          </div>
          <div>
            <span class="font-semibold text-white">Competitors</span>
            <span class="text-gray-400"> — Number of known existing solutions in the space</span>
          </div>
          <div>
            <span class="font-semibold text-white">Source</span>
            <span class="text-gray-400"> — Platform where the demand signal was detected (Reddit, HN, etc.)</span>
          </div>
          <div>
            <span class="font-semibold text-white">TAM / SAM / SOM</span>
            <span class="text-gray-400"> — Total, Serviceable, and Obtainable market size estimates</span>
          </div>
          <div>
            <span class="font-semibold text-white">MVP Timeline</span>
            <span class="text-gray-400"> — Estimated time to build a minimum viable product</span>
          </div>
        </div>
      </div>

      <!-- 3c. ECG Divider + Locked Titles -->
      <div class="max-w-3xl mx-auto">
        <!-- ECG Divider 2: between legend and locked titles -->
        <EcgDivider client:load index={1} />

        <h3 class="text-lg font-bold text-white mb-6">
          More from today's scan — <span class="text-gray-400 font-normal">titles only (Pro unlocks full details)</span>
        </h3>

        <div class="space-y-3">
          <div class="flex items-center gap-3 py-2 px-4 rounded-lg bg-white/[0.02] border border-white/5">
            <span class="text-xs font-mono text-gray-600 w-6 text-right">2</span>
            <span class="text-sm text-gray-200 flex-1">AI-Powered Dev Tool Usage Analytics for Engineering Managers</span>
            <svg class="w-4 h-4 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <div class="flex items-center gap-3 py-2 px-4 rounded-lg bg-white/[0.02] border border-white/5">
            <span class="text-xs font-mono text-gray-600 w-6 text-right">3</span>
            <span class="text-sm text-gray-200 flex-1">Open-Source Status Page with AI Incident Summaries</span>
            <svg class="w-4 h-4 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <div class="flex items-center gap-3 py-2 px-4 rounded-lg bg-white/[0.02] border border-white/5">
            <span class="text-xs font-mono text-gray-600 w-6 text-right">4</span>
            <span class="text-sm text-gray-200 flex-1">Micro-SaaS Churn Predictor with Slack Alerts</span>
            <svg class="w-4 h-4 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <div class="flex items-center gap-3 py-2 px-4 rounded-lg bg-white/[0.02] border border-white/5">
            <span class="text-xs font-mono text-gray-600 w-6 text-right">5</span>
            <span class="text-sm text-gray-200 flex-1">AI Resume Tailoring for Non-Tech Roles</span>
            <svg class="w-4 h-4 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <!-- Blurred titles -->
          <div class="flex items-center gap-3 py-2 px-4 rounded-lg bg-white/[0.02] border border-white/5">
            <span class="text-xs font-mono text-gray-600 w-6 text-right">6</span>
            <span class="text-sm text-gray-200 flex-1 blur-[4px] select-none">Community-Driven Code Review Marketplace</span>
            <svg class="w-4 h-4 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <div class="flex items-center gap-3 py-2 px-4 rounded-lg bg-white/[0.02] border border-white/5">
            <span class="text-xs font-mono text-gray-600 w-6 text-right">7</span>
            <span class="text-sm text-gray-200 flex-1 blur-[4px] select-none">Browser Extension for Real-Time API Cost Tracking</span>
            <svg class="w-4 h-4 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <div class="flex items-center gap-3 py-2 px-4 rounded-lg bg-white/[0.02] border border-white/5">
            <span class="text-xs font-mono text-gray-600 w-6 text-right">8</span>
            <span class="text-sm text-gray-200 flex-1 blur-[4px] select-none">Automated Compliance Documentation Generator</span>
            <svg class="w-4 h-4 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <div class="flex items-center gap-3 py-2 px-4 rounded-lg bg-white/[0.02] border border-white/5">
            <span class="text-xs font-mono text-gray-600 w-6 text-right">9</span>
            <span class="text-sm text-gray-200 flex-1 blur-[4px] select-none">Niche Podcast Guest Matching Platform</span>
            <svg class="w-4 h-4 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <div class="flex items-center gap-3 py-2 px-4 rounded-lg bg-white/[0.02] border border-white/5">
            <span class="text-xs font-mono text-gray-600 w-6 text-right">10</span>
            <span class="text-sm text-gray-200 flex-1 blur-[4px] select-none">AI-Powered Competitive Pricing Intelligence</span>
            <svg class="w-4 h-4 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <div class="flex items-center gap-3 py-2 px-4 rounded-lg bg-white/[0.02] border border-white/5">
            <span class="text-xs font-mono text-gray-600 w-6 text-right">11</span>
            <span class="text-sm text-gray-200 flex-1 blur-[4px] select-none">Open-Source Feature Flag Dashboard for Solo Devs</span>
            <svg class="w-4 h-4 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
        </div>

        <!-- Upgrade CTA box -->
        <div class="mt-8 border-2 border-dashed border-cyan-500/40 rounded-xl p-6 text-center">
          <p class="text-gray-300 mb-4">
            See full analysis for all ideas — market sizing, competitors, build plans, and more.
          </p>
          <a
            href="/pro"
            class="inline-block bg-cyan-500 hover:bg-cyan-400 text-white font-semibold px-8 py-3 rounded-lg text-base transition-colors shadow-lg shadow-cyan-500/20"
          >
            Upgrade to Pro &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ECG Divider 3: between Today's Idea and How It Works -->
  <div class="max-w-landing mx-auto px-6">
    <EcgDivider client:load index={2} />
  </div>

  <!-- ===== HOW IT WORKS ===== -->
  <section id="features" class="py-10">
    <div class="max-w-landing mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-16 text-white">
        From noise to signal in three steps
      </h2>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Step 1: Multi-Agent Research -->
        <div class="bg-gray-900/80 border border-gray-800 rounded-xl p-8">
          <div class="w-12 h-12 rounded-full bg-cyan-500/10 flex items-center justify-center mb-5">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cyan-400">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-white">Multi-Agent Research</h3>
          <p class="text-gray-400 leading-relaxed">
            Our pipelines pull ALL trending discussions, launches, and repos across ALL platforms — every day, automatically.
          </p>
        </div>

        <!-- Step 2: Analyze -->
        <div class="bg-gray-900/80 border border-gray-800 rounded-xl p-8">
          <div class="w-12 h-12 rounded-full bg-cyan-500/10 flex items-center justify-center mb-5">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cyan-400">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-white">Analyze</h3>
          <p class="text-gray-400 leading-relaxed">
            Multi-agent AI analysis scores each signal for market demand, feasibility, and competitive landscape.
          </p>
        </div>

        <!-- Step 3: Discover -->
        <div class="bg-gray-900/80 border border-gray-800 rounded-xl p-8">
          <div class="w-12 h-12 rounded-full bg-cyan-500/10 flex items-center justify-center mb-5">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cyan-400">
              <path d="M22 2L11 13"/>
              <path d="M22 2l-7 20-4-9-9-4 20-7z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-white">Discover</h3>
          <p class="text-gray-400 leading-relaxed">
            Browse curated ideas in your feed with powerful search and filtering — by source, score, complexity, market size, or keyword.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ECG Divider 4: between How It Works and Pricing -->
  <div class="max-w-landing mx-auto px-6">
    <EcgDivider client:load index={3} />
  </div>

  <!-- ===== PRICING ===== -->
  <section id="pricing" class="py-10">
    <div class="max-w-landing mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 text-white">
        Simple pricing. No gotchas.
      </h2>
      <p class="text-gray-400 text-center mb-12">
        Start free, upgrade when you're ready.
      </p>

      <div class="grid md:grid-cols-2 gap-6 max-w-2xl mx-auto">
        <!-- Free tier -->
        <div class="bg-gray-900/80 border border-gray-800 rounded-xl p-8">
          <h3 class="font-bold text-lg text-white">Free</h3>
          <p class="text-3xl font-bold mt-2 text-white">$0<span class="text-sm font-normal text-gray-500">/forever</span></p>
          <ul class="mt-6 space-y-3 text-sm text-gray-300">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              1 full idea per day
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              View all titles
            </li>
            <li class="flex items-center gap-2 text-gray-600">
              <svg class="w-4 h-4 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
              Full idea analysis
            </li>
            <li class="flex items-center gap-2 text-gray-600">
              <svg class="w-4 h-4 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
              Search &amp; filter
            </li>
            <li class="flex items-center gap-2 text-gray-600">
              <svg class="w-4 h-4 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
              Daily email digest
            </li>
            <li class="flex items-center gap-2 text-gray-600">
              <svg class="w-4 h-4 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
              Priority support
            </li>
          </ul>
          <a
            href="#"
            id="pricing-cta-free"
            class="block mt-8 text-center border border-gray-600 hover:border-gray-400 text-white font-medium px-6 py-2.5 rounded-lg text-sm transition-colors"
          >
            Get Started Free
          </a>
        </div>

        <!-- Pro tier -->
        <div class="bg-gray-900/80 border-2 border-cyan-500 rounded-xl p-8 relative">
          <span class="absolute -top-3 left-6 bg-cyan-500 text-white text-[11px] font-bold px-3 py-0.5 rounded-full uppercase tracking-wider">
            Pro
          </span>
          <h3 class="font-bold text-lg text-white">Pro</h3>
          <p class="text-3xl font-bold mt-2 text-white">$25<span class="text-sm font-normal text-gray-500">/mo</span></p>
          <ul class="mt-6 space-y-3 text-sm text-gray-300">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-cyan-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-white font-bold">Access to ALL ideas</span>
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-cyan-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-white font-bold">ALL sources</span>
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-cyan-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-white font-bold">Full AI analysis briefs</span>
