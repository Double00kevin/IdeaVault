---
import BaseLayout from "../layouts/BaseLayout.astro";
import IdeaFeed from "../components/IdeaFeed";
---

<BaseLayout title="IdeaVault — AI-analyzed startup ideas, daily.">
  <!-- Minimal hero -->
  <div class="mb-6">
    <h1 class="text-lg font-bold text-text-primary">
      AI-analyzed startup ideas, daily.
    </h1>
    <p class="text-sm text-text-secondary mt-1">
      Demand signals from Reddit, Product Hunt, and Google Trends, analyzed by AI.
      Build complexity, market size, competitors, and a confidence score for each.
    </p>
  </div>

  <!-- React island: interactive feed -->
  <IdeaFeed client:load />
</BaseLayout>
