---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProCheckout from "../components/ProCheckout";
---

<BaseLayout title="Go Pro — AIdeaPulse" description="Unlock 1,000 ideas per day, daily email digests, and priority support.">
  <div class="space-y-8">
    <div>
      <h1 class="text-2xl font-bold text-white">AIdeaPulse Pro</h1>
      <p class="text-gray-400 mt-2">
        Everything in Free, plus more ideas, daily digests, and priority support.
      </p>
    </div>

    <!-- Pricing cards -->
    <div class="grid gap-6 sm:grid-cols-2">
      <!-- Free tier -->
      <div class="border border-gray-800 rounded-xl bg-gray-900 p-6">
        <h2 class="font-bold text-white text-lg">Free</h2>
        <p class="text-3xl font-bold text-white mt-2">$0</p>
        <p class="text-sm text-gray-400 mb-5">Forever</p>
        <ul class="text-sm text-gray-400 space-y-3">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-complexity-low flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            50 ideas per day
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-complexity-low flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            All 8 sources
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-complexity-low flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            AI analysis briefs
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-complexity-low flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            Save &amp; rate ideas
          </li>
          <li class="flex items-center gap-2 text-gray-600">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            Daily email digest
          </li>
          <li class="flex items-center gap-2 text-gray-600">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            Priority support
          </li>
        </ul>
        <a
          href="/"
          class="block mt-6 text-center border border-gray-600 hover:border-gray-400 text-white font-medium px-4 py-2 rounded-lg text-sm transition-colors"
        >
          Browse Ideas Free
        </a>
      </div>

      <!-- Pro tier -->
      <div class="border-2 border-cyan-500 rounded-xl bg-gray-900 p-6 relative">
        <span class="absolute -top-3 left-5 bg-accent text-white text-[11px] font-bold px-3 py-0.5 rounded-full uppercase tracking-wider">
          Pro
        </span>
        <h2 class="font-bold text-white text-lg">Pro</h2>
        <p class="text-3xl font-bold text-white mt-2">
          $25<span class="text-sm font-normal text-gray-400">/mo</span>
        </p>
        <p class="text-sm text-gray-400 mb-5">Cancel anytime</p>
        <ul class="text-sm text-gray-400 space-y-3">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-complexity-low flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            1,000 ideas per day
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-complexity-low flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            All 8 sources
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-complexity-low flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            AI analysis briefs
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-complexity-low flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            Save &amp; rate ideas
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-cyan-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span class="text-white">Daily email digest</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-cyan-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span class="text-white">Priority support</span>
          </li>
        </ul>
        <div class="mt-6">
          <ProCheckout client:load />
        </div>
      </div>
    </div>

    <!-- Comparison callout -->
    <p class="text-sm text-gray-400 italic text-center">
      IdeaBrowser charges $499&ndash;$1,499/year for fewer sources and rationed AI. AIdeaPulse Pro is $300/year with unlimited AI analysis.
    </p>

    <div class="pt-4 border-t border-gray-800">
      <a href="/" class="text-cyan-400 hover:underline text-sm">
        &larr; Browse ideas
      </a>
    </div>
  </div>
</BaseLayout>
