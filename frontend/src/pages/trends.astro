---
import BaseLayout from "../layouts/BaseLayout.astro";
import TrendsDashboard from "../components/TrendsDashboard";
---

<BaseLayout title="Trends — AIdeaPulse" description="Discover trending keywords and emerging market opportunities. Powered by real-time data from 13 sources.">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-white mb-2">Trends</h1>
      <p class="text-gray-400">
        Discover emerging keywords and market opportunities from Google Trends data, updated daily.
      </p>
    </div>

    <TrendsDashboard client:load />
  </div>
</BaseLayout>
