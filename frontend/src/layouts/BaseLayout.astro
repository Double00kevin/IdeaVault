---
import HeaderAuth from "../components/HeaderAuth";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  fullWidth?: boolean;
}

const {
  title,
  description = "AI-analyzed startup ideas, daily.",
  ogImage,
  fullWidth = false,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://aideapulse.com");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <header class="fixed top-0 left-0 right-0 z-50 bg-[#0a0a0f]/80 backdrop-blur-md border-b border-gray-800/50">
      <nav class="max-w-landing mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="font-bold text-white text-lg tracking-tight flex items-center gap-2">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-accent">
            <circle cx="12" cy="12" r="3" fill="currentColor" opacity="0.9"/>
            <circle cx="12" cy="12" r="7" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
            <circle cx="12" cy="12" r="11" stroke="currentColor" stroke-width="1" opacity="0.2"/>
          </svg>
          AIdeaPulse
        </a>
        <div class="hidden sm:flex items-center gap-8 text-sm text-gray-400">
          <a href="/#features" class="hover:text-white transition-colors">Features</a>
          <a href="/#pricing" class="hover:text-white transition-colors">Pricing</a>
          <a href="/about" class="hover:text-white transition-colors">About</a>
        </div>
        <div class="flex items-center gap-3">
          <HeaderAuth client:load />
        </div>
      </nav>
    </header>

    <!-- Spacer for fixed nav -->
    <div class="h-16"></div>

    {fullWidth ? (
      <main id="main">
        <slot />
      </main>
    ) : (
      <main id="main" class="max-w-content mx-auto px-4 py-6">
        <slot />
      </main>
    )}

    {!fullWidth && (
      <footer class="border-t border-gray-800 mt-12 py-6">
        <div class="max-w-content mx-auto px-4 text-xs text-gray-500 flex flex-wrap items-center gap-x-4 gap-y-1">
          <span>&copy; 2026 AIdeaPulse. AI-analyzed startup ideas, daily.</span>
          <a href="/privacy" class="hover:text-gray-300 transition-colors">Privacy Policy</a>
          <a href="/terms" class="hover:text-gray-300 transition-colors">Terms of Service</a>
        </div>
      </footer>
    )}
  </body>
</html>
